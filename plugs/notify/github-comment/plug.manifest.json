{
  "$schema": "../../../packages/socket/schemas/plug-manifest.v1.json",
  "schemaVersion": "1.0.0",
  "id": "notify-github-comment",
  "name": "GitHub Pull Request Comment",
  "owner": "notify",
  "version": "0.0.1",
  "description": "Posts review results through an installation-authorized GitHub App.",
  "capabilities": ["post"],
  "targets": { "providers": ["github"], "plans": [], "env": [] },
  "dependencies": { "requires": [], "recommends": [] },
  "permissions": {
    "network": ["api.github.com:443"],
    "filesystem": [],
    "env": ["GITGECKO_GITHUB_APP_ID", "GITGECKO_GITHUB_APP_PRIVATE_KEY"],
    "mutatesTools": true
  },
  "entrypoint": "./plug.ts",
  "hooks": false,
  "mcp": false
}
