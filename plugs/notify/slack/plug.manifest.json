{
  "$schema": "../../../packages/socket/schemas/plug-manifest.v1.json",
  "schemaVersion": "1.0.0",
  "id": "notify-slack-conversation",
  "name": "Slack Conversation",
  "owner": "notify",
  "version": "0.0.1",
  "description": "Posts GitGecko review updates to an existing Slack conversation through chat.postMessage.",
  "capabilities": ["post"],
  "targets": { "providers": ["slack"], "plans": [], "env": [] },
  "dependencies": { "requires": [], "recommends": [] },
  "permissions": {
    "network": ["slack.com:443"],
    "filesystem": [],
    "env": ["GITGECKO_SLACK_BOT_TOKEN"],
    "mutatesTools": true
  },
  "entrypoint": "./plug.ts",
  "hooks": false,
  "mcp": false
}
