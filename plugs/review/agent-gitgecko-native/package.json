{
  "name": "@gitgecko/plug-agent-gitgecko-native",
  "version": "0.0.1",
  "private": true,
  "description": "First-party agent backend for the review owner (P-plugin-3 Agent adapter). A minimal agent loop for air-gapped/no-external-agent deployments. Salvages SWE-agent's lean agent-computer interface (P-plugin-10).",
  "type": "module",
  "exports": {
    ".": "./dist/plug.js"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "rimraf dist && tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@gitgecko/core": "workspace:*",
    "@gitgecko/instructions": "workspace:*",
    "@gitgecko/review": "workspace:*",
    "@gitgecko/socket": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.0.0",
    "rimraf": "6.0.0",
    "tsx": "4.19.0",
    "typescript": "5.6.3"
  },
  "main": "./dist/plug.js",
  "types": "./dist/plug.d.ts"
}
