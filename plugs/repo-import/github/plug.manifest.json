{
  "$schema": "../../../packages/socket/schemas/plug-manifest.v1.json",
  "schemaVersion": "1.0.0",
  "id": "repo-import-github-app",
  "name": "GitHub App Source",
  "owner": "repo-import",
  "version": "0.0.1",
  "description": "Installation-scoped GitHub repository verification and pull-request diff retrieval.",
  "capabilities": ["installation-verify", "installation-repositories", "pull-request-diff", "pull-request-linked-issues", "repository-snapshot"],
  "targets": { "providers": ["github"], "plans": [], "env": [] },
  "dependencies": { "requires": [], "recommends": [] },
  "permissions": {
    "network": ["api.github.com:443"],
    "filesystem": [],
    "env": ["GITGECKO_GITHUB_APP_ID", "GITGECKO_GITHUB_APP_PRIVATE_KEY"],
    "mutatesTools": false
  },
  "entrypoint": "./plug.ts",
  "hooks": false,
  "mcp": false
}
