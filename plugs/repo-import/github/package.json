{
  "name": "@gitgecko/plug-repo-import-github",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "GitHub App source plug for the GitGecko repository-import owner.",
  "exports": {
    ".": "./dist/plug.js"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx plug.test.ts"
  },
  "dependencies": {
    "@gitgecko/repo-import": "workspace:*",
    "@gitgecko/socket": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.0.0",
    "rimraf": "6.0.0",
    "tsx": "4.19.0",
    "typescript": "5.6.3"
  },
  "main": "./dist/plug.js",
  "types": "./dist/plug.d.ts"
}
