# GitGecko CLI — optional environment variables.
#
# The CLI works zero-config with a detected native agent (Codex, Claude Code,
# OpenCode). The variables below are only needed when using a specific pathway.
# All are optional. Copy to .env if your workflow reads from there, or set them
# in your shell.
#
# Cloud-side / dashboard / hosted-offering variables are intentionally not
# documented here — they belong to the operator plane, not the CLI consumer.

# ── BYOK model providers (use a cloud-pathway review with your own key) ──────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Local model server (LM Studio, Ollama, vLLM, any OpenAI-compatible) ──────
# Configure via `gitgecko models configure --base-url ... --model ...` instead
# of editing this file — the CLI persists the route to ~/.gitgecko/config.json.
GITGECKO_LOCAL_BASE_URL=
GITGECKO_LOCAL_MODEL=
GITGECKO_LOCAL_PROTOCOL=openai-chat-completions  # openai-chat-completions | openai-responses | anthropic-messages
GITGECKO_LOCAL_API_KEY=                          # optional; some local servers require a non-empty bearer value
GITGECKO_LOCAL_PREFER=                           # when both local and a native agent are available, prefer local

# ── Native-agent per-agent overrides (optional) ──────────────────────────────
ANTHROPIC_MODEL=
OPENAI_MODEL=
OPENAI_BASE_URL=
CLAUDE_MODEL=
CODEX_MODEL=
OPENCODE_MODEL=

# Per-agent timeout (ms, default 180000 = 3min)
CLAUDE_TIMEOUT_MS=
CODEX_TIMEOUT_MS=
OPENCODE_TIMEOUT_MS=

# ── Cloud account linking (optional) ─────────────────────────────────────────
# `gitgecko auth` opens a browser to link this device to a hosted account so
# reviews can appear in the dashboard. Default is the public cloud; self-hosted
# operators set this to their own URL.
GITGECKO_CLOUD_URL=https://app.gitgecko.com
GITGECKO_NO_BROWSER=             # set 1 for headless device linking; the verification URL is still printed
