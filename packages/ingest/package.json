{
  "name": "@gitgecko/ingest",
  "version": "0.0.0",
  "private": true,
  "description": "gitgecko ingest owner — receives events (webhooks, API, crons, slash-commands) and routes them to the right owner (02 §2). IngestSocket { receive(event): Route }. The entry point for the request lifecycle.",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx src/**/*.test.ts"
  },
  "dependencies": {
    "@gitgecko/core": "workspace:*",
    "@gitgecko/socket": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.0.0",
    "rimraf": "6.0.0",
    "tsx": "4.19.0",
    "typescript": "5.6.3"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
