{
  "name": "@gitgecko/model-client",
  "version": "0.0.0",
  "private": true,
  "description": "The canonical model owner and cloud-pathway LLM transport. Delegates provider HTTP, streaming, compatibility, auth, retry, and provider catalogs to @earendil-works/pi-ai. Owns the gitgecko-light/gitgecko-high hosted catalog, provider auto-detection, and the /v1/models discovery surface.",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./gitgecko-models": {
      "types": "./dist/gitgecko-models.d.ts",
      "import": "./dist/gitgecko-models.js",
      "default": "./dist/gitgecko-models.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx src/**/*.test.ts"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.80.3",
    "@gitgecko/core": "workspace:*",
    "@gitgecko/plans": "workspace:*",
    "undici": "8.7.0"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "tsx": "4.19.0",
    "@types/node": "22.0.0",
    "rimraf": "6.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
