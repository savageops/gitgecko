  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "5.6.3",
    "tsx": "4.19.0",
    "@types/node": "22.0.0",
    "rimraf": "6.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
