{
  "name": "@gitgecko/plans",
  "version": "0.0.1",
  "private": true,
  "description": "The public plan-tier model + the plan-enforcement gate. Pure, dependency-light, and the only piece of the billing surface the published CLI needs (for the cloud-pathway plan gate).",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./plans": "./dist/plans.js"
