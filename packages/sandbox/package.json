{
  "name": "@gitgecko/sandbox",
  "version": "0.0.0",
  "private": true,
  "description": "GitGecko sandbox owner contract for bounded tool execution. Backends declare whether they enforce isolation; subprocess execution is trusted-local only.",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./socket": "./dist/socket.js"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx src/**/*.test.ts"
  },
  "dependencies": {
    "@gitgecko/core": "workspace:*",
    "@gitgecko/socket": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "tsx": "4.19.0",
    "@types/node": "22.0.0",
    "rimraf": "6.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
