{
  "name": "@gitgecko/socket",
  "version": "0.0.0",
  "private": true,
  "description": "GitGecko's runtime for proven interchangeable capabilities: manifest schema, lifecycle registry, and derived mutation gates. Owner policy stays stable while provider translation plugs are swapped.",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./manifest": "./dist/manifest.js",
    "./registry": "./dist/registry.js"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx src/**/*.test.ts"
  },
  "dependencies": {
    "@gitgecko/core": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "tsx": "4.19.0",
    "@types/node": "22.0.0",
    "rimraf": "6.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
